main test_cases.arc4_numeric_comparisons.uint_n.UIntNOrdering.approval_program:
    block@0: // L8
        let tmp%0#0: Encoded(uint8) = bytes_encode<uint8>(1u)
        let tmp%1#0: Encoded(uint64) = bytes_encode<uint64>(2u)
        test_cases.arc4_numeric_comparisons.uint_n.check_both_uint_n(tmp%0#0, tmp%1#0)
        let tmp%2#0: Encoded(uint8) = bytes_encode<uint8>(1u)
        let tmp%3#0: Encoded(uint264) = bytes_encode<uint264>(2b)
        test_cases.arc4_numeric_comparisons.uint_n.check_mixed(tmp%2#0, tmp%3#0)
        let tmp%4#0: Encoded(uint256) = bytes_encode<uint256>(1b)
        let tmp%5#0: Encoded(uint264) = bytes_encode<uint264>(2b)
        test_cases.arc4_numeric_comparisons.uint_n.check_both_big_uint_n(tmp%4#0, tmp%5#0)
        return 1u

