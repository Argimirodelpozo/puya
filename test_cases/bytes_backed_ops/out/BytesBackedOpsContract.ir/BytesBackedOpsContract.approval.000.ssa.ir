subroutine test_cases.bytes_backed_ops.contract.test_byte_manipulation_ops() -> void:
    block@0: // L96
        let fb#0: bytes[5] = 0x68656c6c6f
        let s#0: string = "hello"
        let awst_tmp%0#0: account = (txn Sender)
        let tmp%0#0: uint64 = (len awst_tmp%0#0)
        let tmp%1#0: bool = (== 32u tmp%0#0)
        (assert tmp%1#0) // Address length is 32 bytes
        let acct#0: account = awst_tmp%0#0
        let tmp%2#0: bytes = (concat fb#0 s#0)
        let result#0: bytes = tmp%2#0
        let tmp%3#0: uint64 = (len result#0)
        let tmp%4#0: bool = (== tmp%3#0 10u)
        (assert tmp%4#0)
        let tmp%5#0: Encoded(len+utf8[]) = bytes_encode<(len+utf8[])>("hello")
        let tmp%6#0: bytes = (concat tmp%5#0 acct#0)
        let tmp%7#0: uint64 = (len tmp%6#0)
        let tmp%8#0: bool = (!= tmp%7#0 0u)
        (assert tmp%8#0)
        let tmp%9#0: bytes = (concat acct#0 s#0)
        let tmp%10#0: uint64 = (len tmp%9#0)
        let tmp%11#0: bool = (!= tmp%10#0 0u)
        (assert tmp%11#0)
        let tmp%12#0: bytes = (concat 1000b 1000b)
        let tmp%13#0: uint64 = (len tmp%12#0)
        let tmp%14#0: bool = (!= tmp%13#0 0u)
        (assert tmp%14#0)
        let tmp%15#0: Encoded(len+uint8[]) = bytes_encode<(len+uint8[])>(0x00026869)
        let tmp%16#0: bytes = (concat tmp%15#0 fb#0)
        let tmp%17#0: uint64 = (len tmp%16#0)
        let tmp%18#0: bool = (!= tmp%17#0 0u)
        (assert tmp%18#0)
        let tmp%19#0: Encoded(uint64) = bytes_encode<uint64>(42u)
        let tmp%20#0: Encoded(uint64) = bytes_encode<uint64>(43u)
        let tmp%21#0: bytes = (concat tmp%19#0 tmp%20#0)
        let tmp%22#0: uint64 = (len tmp%21#0)
        let tmp%23#0: bool = (!= tmp%22#0 0u)
        (assert tmp%23#0)
        let encoded_array%0#0: Encoded(len+uint64[]) = bytes_encode<(len+uint64[])>(10u, 20u)
        let tmp%24#0: bytes = (concat encoded_array%0#0 fb#0)
        let tmp%25#0: uint64 = (len tmp%24#0)
        let tmp%26#0: bool = (!= tmp%25#0 0u)
        (assert tmp%26#0)
        let encoded_array%1#0: Encoded(len+uint64[]) = bytes_encode<(len+uint64[])>(1u)
        let tmp%27#0: Encoded(uint64,uint64) = bytes_encode<(uint64,uint64)>(1u, 2u)
        let tmp%28#0: bytes = (concat encoded_array%1#0 tmp%27#0)
        let tmp%29#0: uint64 = (len tmp%28#0)
        let tmp%30#0: bool = (!= tmp%29#0 0u)
        (assert tmp%30#0)
        let tmp%31#0: bytes = ((extract 1 3) s#0)
        let tmp%32#0: bool = (== tmp%31#0 0x656c6c)
        (assert tmp%32#0)
        let tmp%33#0: bytes = ((extract 0 4) acct#0)
        let tmp%34#0: uint64 = (len tmp%33#0)
        let tmp%35#0: bool = (!= tmp%34#0 0u)
        (assert tmp%35#0)
        let tmp%36#0: Encoded(len+utf8[]) = bytes_encode<(len+utf8[])>("hello")
        let tmp%37#0: bytes = ((extract 0 2) tmp%36#0)
        let tmp%38#0: uint64 = (len tmp%37#0)
        let tmp%39#0: bool = (!= tmp%38#0 0u)
        (assert tmp%39#0)
        let tmp%40#0: bytes = (substring3 fb#0 1u 4u)
        let tmp%41#0: bool = (== tmp%40#0 0x656c6c)
        (assert tmp%41#0)
        let tmp%42#0: Encoded(uint64) = bytes_encode<uint64>(42u)
        let tmp%43#0: bytes = (substring3 tmp%42#0 0u 4u)
        let tmp%44#0: uint64 = (len tmp%43#0)
        let tmp%45#0: bool = (!= tmp%44#0 0u)
        (assert tmp%45#0)
        let tmp%46#0: Encoded(uint64) = bytes_encode<uint64>(42u)
        let tmp%47#0: uint64 = (getbyte tmp%46#0 7u)
        let tmp%48#0: bool = (== tmp%47#0 42u)
        (assert tmp%48#0)
        let tmp%49#0: uint64 = (getbyte 1000b 0u)
        let tmp%50#0: bool = (>= tmp%49#0 0u)
        (assert tmp%50#0)
        let tmp%51#0: uint64 = (getbyte s#0 0u)
        let tmp%52#0: bool = (== tmp%51#0 104u)
        (assert tmp%52#0)
        let tmp%53#0: bytes = (setbyte fb#0 0u 72u)
        let modified#0: bytes = tmp%53#0
        let tmp%54#0: bool = (== modified#0 0x48656c6c6f)
        (assert tmp%54#0)
        let tmp%55#0: bytes = (replace3 256b 0u 0x00)
        let replaced#0: bytes = tmp%55#0
        let tmp%56#0: uint64 = (len replaced#0)
        let tmp%57#0: bool = (!= tmp%56#0 0u)
        (assert tmp%57#0)
        let tmp%58#0: bytes = (replace3 acct#0 0u 0x00)
        let replaced2#0: bytes = tmp%58#0
        let tmp%59#0: uint64 = (len replaced2#0)
        let tmp%60#0: bool = (!= tmp%59#0 0u)
        (assert tmp%60#0)
        let fb8#0: bytes[8] = 0x000000000000002a
        let tmp%61#0: uint64 = (extract_uint64 fb8#0 0u)
        let tmp%62#0: bool = (== tmp%61#0 42u)
        (assert tmp%62#0)
        let tmp%63#0: Encoded(uint32) = bytes_encode<uint32>(1000u)
        let tmp%64#0: uint64 = (extract_uint16 tmp%63#0 0u)
        let tmp%65#0: bool = (>= tmp%64#0 0u)
        (assert tmp%65#0)
        let tmp%66#0: Encoded(uint32) = bytes_encode<uint32>(1000u)
        let tmp%67#0: uint64 = (extract_uint32 tmp%66#0 0u)
        let tmp%68#0: bool = (>= tmp%67#0 0u)
        (assert tmp%68#0)
        return 

subroutine test_cases.bytes_backed_ops.contract.test_conversion_ops() -> void:
    block@0: // L146
        let fb#0: bytes[8] = 0x000000000000002a
        let tmp%0#0: uint64 = (btoi fb#0)
        let tmp%1#0: bool = (== tmp%0#0 42u)
        (assert tmp%1#0)
        let tmp%2#0: Encoded(uint64) = bytes_encode<uint64>(100u)
        let tmp%3#0: uint64 = (btoi tmp%2#0)
        let tmp%4#0: bool = (== tmp%3#0 100u)
        (assert tmp%4#0)
        let tmp%5#0: uint64 = (btoi 0x2a)
        let tmp%6#0: bool = (== tmp%5#0 42u)
        (assert tmp%6#0)
        let encoded#0: bytes = 0x614756736247383d
        let tmp%7#0: bytes = ((base64_decode StdEncoding) encoded#0)
        let decoded#0: bytes = tmp%7#0
        let tmp%8#0: bool = (== decoded#0 0x68656c6c6f)
        (assert tmp%8#0)
        return 

subroutine test_cases.bytes_backed_ops.contract.test_bitwise_ops() -> void:
    block@0: // L160
        let fb#0: bytes[4] = 0x74657374
        let s#0: string = "test"
        let awst_tmp%0#0: account = (txn Sender)
        let tmp%0#0: uint64 = (len awst_tmp%0#0)
        let tmp%1#0: bool = (== 32u tmp%0#0)
        (assert tmp%1#0) // Address length is 32 bytes
        let acct#0: account = awst_tmp%0#0
        let tmp%2#0: uint64 = (bitlen fb#0)
        let tmp%3#0: bool = (> tmp%2#0 0u)
        (assert tmp%3#0)
        let tmp%4#0: uint64 = (bitlen s#0)
        let tmp%5#0: bool = (> tmp%4#0 0u)
        (assert tmp%5#0)
        let tmp%6#0: uint64 = (bitlen acct#0)
        let tmp%7#0: bool = (> tmp%6#0 0u)
        (assert tmp%7#0)
        let tmp%8#0: uint64 = (bitlen 1000b)
        let tmp%9#0: bool = (> tmp%8#0 0u)
        (assert tmp%9#0)
        let tmp%10#0: Encoded(uint64) = bytes_encode<uint64>(42u)
        let tmp%11#0: uint64 = (bitlen tmp%10#0)
        let tmp%12#0: bool = (> tmp%11#0 0u)
        (assert tmp%12#0)
        let tmp%13#0: Encoded(len+utf8[]) = bytes_encode<(len+utf8[])>("hello")
        let tmp%14#0: uint64 = (bitlen tmp%13#0)
        let tmp%15#0: bool = (> tmp%14#0 0u)
        (assert tmp%15#0)
        let tmp%16#0: Encoded(len+uint8[]) = bytes_encode<(len+uint8[])>(0x00026869)
        let tmp%17#0: uint64 = (bitlen tmp%16#0)
        let tmp%18#0: bool = (> tmp%17#0 0u)
        (assert tmp%18#0)
        let tmp%19#0: Encoded(uint8) = bytes_encode<uint8>(1u)
        let tmp%20#0: Encoded(len+utf8[]) = bytes_encode<(len+utf8[])>("hello")
        let tmp%21#0: Encoded(uint8,(len+utf8[])) = bytes_encode<(uint8,(len+utf8[]))>(tmp%19#0, tmp%20#0)
        let tmp%22#0: uint64 = (bitlen tmp%21#0)
        let tmp%23#0: bool = (> tmp%22#0 0u)
        (assert tmp%23#0)
        let tmp%24#0: Encoded(uint64) = bytes_encode<uint64>(42u)
        let tmp%25#0: Encoded(uint8) = bytes_encode<uint8>(7u)
        let tmp%26#0: Encoded(uint64,uint8) = bytes_encode<(uint64,uint8)>(tmp%24#0, tmp%25#0)
        let tmp%27#0: uint64 = (bitlen tmp%26#0)
        let tmp%28#0: bool = (> tmp%27#0 0u)
        (assert tmp%28#0)
        let encoded_array%0#0: Encoded(len+uint64[]) = bytes_encode<(len+uint64[])>(1u, 2u, 3u)
        let tmp%29#0: uint64 = (bitlen encoded_array%0#0)
        let tmp%30#0: bool = (> tmp%29#0 0u)
        (assert tmp%30#0)
        let tmp%31#0: Encoded(uint64,uint64) = bytes_encode<(uint64,uint64)>(1u, 2u)
        let tmp%32#0: uint64 = (bitlen tmp%31#0)
        let tmp%33#0: bool = (> tmp%32#0 0u)
        (assert tmp%33#0)
        let tmp%34#0: bool = (getbit s#0 0u)
        let bit#0: bool = tmp%34#0
        let tmp%35#0: bool = (! bit#0)
        let tmp%36#0: bytes = (setbit s#0 0u tmp%35#0)
        let result#0: bytes = tmp%36#0
        let tmp%37#0: bool = (!= result#0 s#0)
        (assert tmp%37#0)
        let tmp%38#0: bool = (getbit fb#0 0u)
        let bit2#0: bool = tmp%38#0
        let tmp%39#0: bool = (! bit2#0)
