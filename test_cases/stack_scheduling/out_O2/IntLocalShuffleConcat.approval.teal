#pragma version 11
#pragma typetrack false

// test_cases.stack_scheduling.contract.IntLocalShuffleConcat.approval_program() -> uint64:
main:
    txn NumAppArgs
    txna ApplicationArgs 0
    txna ApplicationArgs 1
    dup
    txna ApplicationArgs 0
    txn NumAppArgs
    dup
    itob
    uncover 2
    concat
    uncover 2
    concat
    log
    pushint 1
    >
    bz main_after_if_else@2
    dig 2
    pushint 1
    +
    itob
    dig 1
    concat
    dig 2
    concat
    log

main_after_if_else@2:
    pushint 1
    return
