#pragma version 11
#pragma typetrack false

// test_cases.stack_scheduling.contract.SubroutineParamSwapConcat.approval_program() -> uint64:
main:
    txna ApplicationArgs 0
    txna ApplicationArgs 1
    txn NumAppArgs
    pushint 2
    >
    bz main_after_if_else@3
    txna ApplicationArgs 2
    swap
    bury 2

main_after_if_else@3:
    dig 1
    dup
    uncover 2
    concat
    swap
    concat
    log
    pushint 1
    return
