main test_cases.stack_scheduling.contract.ConstPrefixConcat.approval_program:
    block@0: // L17
        let prefix#0: bytes = 0x6c6f673a
        let tmp%0#0: uint64 = (txn NumAppArgs)
        let tmp%1#0: bytes = (itob tmp%0#0)
        let value#0: bytes = tmp%1#0
        let tmp%2#0: bytes = (concat prefix#0 value#0)
        (log tmp%2#0)
        return 1u