main test_cases.stack_scheduling.contract.DupedLocalConcat.approval_program:
    block@0: // L88
        let x#0: bytes = (txna ApplicationArgs 0)
        let y#0: bytes = (txna ApplicationArgs 1)
        let tmp%2#0: bytes = (concat x#0 y#0)
        let tmp%3#0: bytes = (concat tmp%2#0 x#0)
        let tmp%4#0: bytes = (concat tmp%3#0 y#0)
        (log tmp%4#0)
        return 1u