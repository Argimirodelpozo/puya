main test_cases.stack_scheduling.contract.FrameMutateInLoopConcat.approval_program:
    block@0: // L61
        let result#0: bytes = 0x
        let sep#0: bytes = 0x2c
        let tmp%0#0: uint64 = (txn NumAppArgs)
        (assert 1u) // Step cannot be zero
        let value_internal%0#0: uint64 = 0u
        goto block@1
    block@1: // for_header_L64
        let value_internal%0#1: uint64 = φ(value_internal%0#0 <- block@0, value_internal%0#2 <- block@3)
        let result#1: bytes = φ(result#0 <- block@0, result#2 <- block@3)
        let continue_looping%0#0: bool = (< value_internal%0#1 tmp%0#0)
        goto continue_looping%0#0 ? block@2 : block@4
    block@2: // for_body_L65
        let i#0: uint64 = value_internal%0#1
        let tmp%1#0: bytes = (concat result#1 sep#0)
        let tmp%2#0: bytes = ((txnas ApplicationArgs) i#0)
        let tmp%3#0: bytes = (concat tmp%1#0 tmp%2#0)
        let result#2: bytes = tmp%3#0
        goto block@3
    block@3: // for_footer_L64
        let value_internal%0#2: uint64 = (+ value_internal%0#1 1u)
        goto block@1
    block@4: // after_for_L64
        (log result#1)
        return 1u