// Op                                              Stack (out)
// test_cases.stack_scheduling.contract.IntLocalShuffleConcat.approval_program() -> uint64:
subroutine main:
    main_block@0:
        // stack_scheduling/contract.py:100
        // n = Txn.num_app_args
        txn NumAppArgs                             n#0
        l-store-copy n#0 0                         n#0,n#0 (copy)
        v-store n#0                                n#0
        // stack_scheduling/contract.py:101
        // a = Txn.application_args(0)
        txna ApplicationArgs 0                     n#0,a#0
        l-store-copy a#0 1                         a#0,n#0,a#0 (copy)
        v-store a#0                                a#0,n#0
        // stack_scheduling/contract.py:102
        // b = Txn.application_args(1)
        txna ApplicationArgs 1                     a#0,n#0,b#0
        l-store-copy b#0 2                         b#0,a#0,n#0,b#0 (copy)
        v-store b#0                                b#0,a#0,n#0
        // stack_scheduling/contract.py:103
        // log(op.itob(n) + a + b)
        l-load-copy n#0 0                          b#0,a#0,n#0,n#0 (copy)
        itob                                       b#0,a#0,n#0,tmp%3#0
        l-load tmp%3#0 0                           b#0,a#0,n#0,tmp%3#0
        l-load a#0 2                               b#0,n#0,tmp%3#0,a#0
        concat                                     b#0,n#0,tmp%4#0
        l-load tmp%4#0 0                           b#0,n#0,tmp%4#0
        l-load b#0 2                               n#0,tmp%4#0,b#0
        concat                                     n#0,tmp%5#0
        l-load tmp%5#0 0                           n#0,tmp%5#0
        log                                        n#0
        // stack_scheduling/contract.py:104
        // if n > 1:
        l-load n#0 0                               n#0
        int 1                                      n#0,1
        >                                          tmp%6#0
        l-load tmp%6#0 0                           tmp%6#0
        bz main_after_if_else@2 ; b main_if_body@1

    main_if_body@1:
        // stack_scheduling/contract.py:105
        // log(op.itob(n + 1) + b + a)
        v-load n#0                                 n#0
        int 1                                      n#0,1
        +                                          tmp%7#0
        l-load tmp%7#0 0                           tmp%7#0
        itob                                       tmp%8#0
        l-load tmp%8#0 0                           tmp%8#0
        v-load b#0                                 tmp%8#0,b#0
        concat                                     tmp%9#0
        l-load tmp%9#0 0                           tmp%9#0
        v-load a#0                                 tmp%9#0,a#0
        concat                                     tmp%10#0
        l-load tmp%10#0 0                          tmp%10#0
        log
        b main_after_if_else@2

    main_after_if_else@2:
        // stack_scheduling/contract.py:106
        // return True
        int 1                                      1
        return


