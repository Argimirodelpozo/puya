main test_cases.stack_scheduling.contract.OpPrefixConcat.approval_program:
    block@0: // L5
        let tmp%0#0: uint64 = (txn NumAppArgs)
        let a#0: uint64 = tmp%0#0
        let tmp%1#0: bytes = ((txnas ApplicationArgs) 0u)
        let b#0: bytes = tmp%1#0
        let tmp%2#0: bytes = (itob a#0)
        let tmp%3#0: bytes = (concat tmp%2#0 b#0)
        let c#0: bytes = tmp%3#0
        (log c#0)
        return 1u