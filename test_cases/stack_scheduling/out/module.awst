contract IntLocalShuffleConcat
{
  method_resolution_order: (
    algopy._contract.Contract,
  )
  
  subroutine test_cases.stack_scheduling.contract.IntLocalShuffleConcat.approval_program(): bool
  {
    n: uint64 = txn<NumAppArgs>()
    a: bytes = txnas<ApplicationArgs>(0u)
    b: bytes = txnas<ApplicationArgs>(1u)
    log(itob(n) + a + b)
    if (n > 1u) {
      log(itob(n + 1u) + b + a)
    }
    return true
  }
  
  subroutine test_cases.stack_scheduling.contract.IntLocalShuffleConcat.clear_state_program(): bool
  {
    return true
  }
  
  subroutine algopy._contract.Contract.__init__(): void
  {
  }
}

