contract FrameMutateInLoopConcat
{
  method_resolution_order: (
    algopy._contract.Contract,
  )
  
  subroutine test_cases.stack_scheduling.contract.FrameMutateInLoopConcat.approval_program(): bool
  {
    result: bytes = hex<"">
    sep: bytes = hex<"2C">
    for i in range(0u, txn<NumAppArgs>(), 1u) {
