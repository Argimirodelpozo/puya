contract SubroutineParamSwapConcat
{
  method_resolution_order: (
    algopy._contract.Contract,
  )
  
  subroutine test_cases.stack_scheduling.contract.SubroutineParamSwapConcat.approval_program(): bool
  {
    log(test_cases.stack_scheduling.contract._swap_and_concat(txnas<ApplicationArgs>(0u), txnas<ApplicationArgs>(1u)))
    return true
  }
  
  subroutine test_cases.stack_scheduling.contract.SubroutineParamSwapConcat.clear_state_program(): bool
  {
    return true
  }
  
  subroutine algopy._contract.Contract.__init__(): void
  {
  }
}

subroutine _chain(a: bytes, b: bytes): bytes
{
  a: bytes = a + b
  return b + a
}

subroutine _swap_and_concat(a: bytes, b: bytes): bytes
{
  if (txn<NumAppArgs>() > 2u) {
    a: bytes = b
    b: bytes = txnas<ApplicationArgs>(2u)
  }
  return a + b + a
}