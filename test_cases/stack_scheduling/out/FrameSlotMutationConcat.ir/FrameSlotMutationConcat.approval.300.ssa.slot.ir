main test_cases.stack_scheduling.contract.FrameSlotMutationConcat.approval_program:
    block@0: // L52
        let a#0: bytes = (txna ApplicationArgs 0)
        let b#0: bytes = (txna ApplicationArgs 1)
        let a#1: bytes = (concat a#0 b#0)
        let tmp%1#1: bytes = (concat b#0 a#1)
        (log tmp%1#1)
        return 1u