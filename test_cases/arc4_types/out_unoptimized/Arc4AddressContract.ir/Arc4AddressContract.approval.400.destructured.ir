main test_cases.arc4_types.address.Arc4AddressContract.approval_program:
    block@0: // L7
        let tmp%0#0: account = (txn Sender)
        let address#0: Encoded(uint8[32]) = tmp%0#0
        let tmp%1#0: account = (txn Sender)
        let tmp%2#0: bool = (== address#0 tmp%1#0)
        (assert tmp%2#0)
        let tmp%3#0: bool = (== 32u 32u)
        (assert tmp%3#0)
        let tmp%4#0: account = (txn Sender)
        let tmp%5#0: bool = (== address#0 tmp%4#0)
        (assert tmp%5#0)
        let awst_tmp%0#0: account = (global ZeroAddress)
        let tmp%6#0: uint64 = (len awst_tmp%0#0)
        let tmp%7#0: bool = (== 32u tmp%6#0)
        (assert tmp%7#0) // Address length is 32 bytes
        let zero_address#0: Encoded(uint8[32]) = awst_tmp%0#0
        let tmp%8#0: account = (global ZeroAddress)
        let tmp%9#0: bool = (== zero_address#0 tmp%8#0)
        (assert tmp%9#0)
        let tmp%10#0: bool = (== addr VCMJKWOY5P5P7SKMZFFOCEROPJCZOTIJMNIYNUCKH7LRO45JMJP6UYBIJA addr VCMJKWOY5P5P7SKMZFFOCEROPJCZOTIJMNIYNUCKH7LRO45JMJP6UYBIJA)
        (assert tmp%10#0)
        let tmp%11#0: bool = (== addr VCMJKWOY5P5P7SKMZFFOCEROPJCZOTIJMNIYNUCKH7LRO45JMJP6UYBIJA addr VCMJKWOY5P5P7SKMZFFOCEROPJCZOTIJMNIYNUCKH7LRO45JMJP6UYBIJA)
        (assert tmp%11#0)
        return 1u