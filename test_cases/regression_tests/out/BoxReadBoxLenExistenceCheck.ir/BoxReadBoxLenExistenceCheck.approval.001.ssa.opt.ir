main algopy.arc4.ARC4Contract.approval_program:
    block@0: // L1
        let tmp%0#0: bool = (txn ApplicationID)
        goto block@2
    block@2: // after_if_else_L1
        let tmp%0#1: uint64 = (txn NumAppArgs)
        let tmp%1#1: bool = (!= tmp%0#1 0u)
        goto tmp%0#1 ? block@4 : block@7
    block@4: // abi_routing_L4
        let tmp%2#0: bytes = (txna ApplicationArgs 0)
        switch tmp%2#0 {method "len_via_value()uint64" => block@5, * => block@6}
    block@5: // len_via_value_route_L8
        let tmp%3#0: uint64 = (txn OnCompletion)
        let tmp%4#0: bool = (! tmp%3#0)
        let tmp%5#0: uint64 = (txn ApplicationID)
        let tmp%6#0: bool = (!= tmp%5#0 0u)
        let tmp%7#0: bool = (&& tmp%4#0 tmp%5#0)
        (assert tmp%7#0)
        test_cases.regression_tests.box_read_box_len_existence_check.BoxReadBoxLenExistenceCheck.len_via_value[routing]()
        goto block@6
    block@6: // switch_case_next_L4
        fail
    block@7: // __algopy_default_create_L1
        let tmp%8#0: uint64 = (txn OnCompletion)
        let tmp%9#0: bool = (! tmp%8#0)
        let tmp%10#0: uint64 = (txn ApplicationID)
        let tmp%11#0: bool = (! tmp%10#0)
        let tmp%12#0: bool = (&& tmp%9#0 tmp%11#0)
        (assert tmp%12#0)
        test_cases.regression_tests.box_read_box_len_existence_check.BoxReadBoxLenExistenceCheck.__algopy_default_create()
        exit 1u

subroutine test_cases.regression_tests.box_read_box_len_existence_check.BoxReadBoxLenExistenceCheck.len_via_value[routing]() -> void:
    block@0: // L8
        let v#0: bytes = box_read(0x6b)
        let (box%box_len%0#0: uint64, box%exists%0#0: bool) = (box_len 0x6b)
        (assert box%exists%0#0) // check self.box exists
        let tmp%0#1: uint64 = box%box_len%0#0
        let tmp%1#0: Encoded(uint64) = bytes_encode<uint64>(tmp%0#1)
        let tmp%2#0: bytes = (concat 0x151f7c75 tmp%1#0)
        (log tmp%2#0)
        exit 1u

subroutine test_cases.regression_tests.box_read_box_len_existence_check.BoxReadBoxLenExistenceCheck.__algopy_default_create() -> void:
    block@0: // L1
        return 