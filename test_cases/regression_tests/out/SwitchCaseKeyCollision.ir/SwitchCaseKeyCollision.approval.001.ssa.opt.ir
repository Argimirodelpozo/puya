main test_cases.regression_tests.switch_case_key_collision.SwitchCaseKeyCollision.approval_program:
    block@0: // L8
        let tmp%0#0: bool = (txn ApplicationID)
        goto block@2
    block@2: // after_if_else_L1
        let tmp%1#0: uint64 = (txn NumAppArgs)
        let x#0: uint64 = (+ tmp%1#0 5u)
        (app_global_put "glob" 5u)
        let (maybe_value%0#0: uint64, maybe_exists%0#0: bool) = (5u, 1u)
        (assert maybe_exists%0#0) // check self.glob exists
        switch x#0 {5u => block@3, maybe_value%0#0 => block@4, * => block@5}
    block@3: // switch_case_0_L16
        let val#0: uint64 = 1u
        goto block@6
    block@4: // switch_case_1_L18
        let val#1: uint64 = 2u
        goto block@6
    block@5: // switch_case_default_L20
        let val#2: uint64 = 3u
        goto block@6
    block@6: // switch_case_next_L14
        let val#3: uint64 = φ(val#0 <- block@3, val#1 <- block@4, val#2 <- block@5)
        let tmp%3#0: bool = (== val#3 1u)
        (assert tmp%3#0) // case 5 must win
        return 1u